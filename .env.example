# ════════════════════════════════════════════════════════════════
# SVU Community — Environment Variables Template
# ════════════════════════════════════════════════════════════════
#
# انسخ هذا الملف إلى .env.local واملأ القيم
# NEVER commit real keys to git
#
# ╔══════════════════════════════════════════════════════════════╗
# ║  أين توضع المفاتيح؟                                        ║
# ╠══════════════════════════════════════════════════════════════╣
# ║                                                            ║
# ║  1. Supabase URL + Anon Key:                               ║
# ║     → محلياً: apps/web/.env (ملف VITE_*)                   ║
# ║     → في Cloudflare (CI/CD): GitHub Secrets                ║
# ║       SUPABASE_URL + SUPABASE_ANON_KEY                     ║
# ║                                                            ║
# ║  2. OCR_API_KEY + GEMINI_API_KEY:                          ║
# ║     → Supabase Edge Functions Secrets فقط                  ║
# ║     → تعيينها: supabase secrets set OCR_API_KEY=xxx        ║
# ║     → أو: bash scripts/setup-secrets.sh                    ║
# ║     → NEVER في ملفات .env أو env.js                        ║
# ║                                                            ║
# ║  3. CF_API_TOKEN + CF_ACCOUNT_ID:                          ║
# ║     → GitHub Secrets فقط (لـ CI/CD)                        ║
# ║                                                            ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # للـ scripts فقط — لا تضعه في العميل

# ─── API Keys (Supabase Edge Functions Secrets) ───────────────
# هذه المفاتيح تُعيَّن في Supabase Dashboard > Edge Functions > Secrets
# أو عبر CLI: supabase secrets set KEY=value
# لا تضعها في أي ملف .env — فهي server-side فقط
#
# OCR_API_KEY    = مفتاح OCR.space لاستخراج النصوص من الصور
# GEMINI_API_KEY = مفتاح Google Gemini لتحليل صور الجداول
# ALLOWED_ORIGINS = أصول CORS المسموحة (https://your-domain.com)

# ─── Cloudflare (CI/CD deployment) ────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# ─── App Configuration ────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
